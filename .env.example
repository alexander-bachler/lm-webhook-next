# --- Core ---
NODE_ENV=development
PORT=3000
# Public URL for browser / callbacks (optional for many features after inline decode)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Persistent data: SQLite (webhooks, devices, jobs) and decoder cache
DATA_DIR=./data

# --- Webhook ingest ---
# Comma-separated shared secrets (any match = authorized). Leave empty to disable auth.
WEBHOOK_SECRET=
# Rate limit: max requests per IP per window
WEBHOOK_RATE_LIMIT_MAX=120
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000

# --- Dashboard data source ---
WEBHOOK_SOURCE=local
WEBHOOK_SITE_TOKEN=
WEBHOOK_SITE_API_KEY=

# --- Admin UI (NextAuth) ---
# Required in production to protect /devices, /api/devices, etc. If unset, middleware allows all routes (dev only).
NEXTAUTH_SECRET=
# URL the app is served on (must match your public URL in production)
NEXTAUTH_URL=http://localhost:3000
ADMIN_USER=admin
# Prefer bcrypt hash in production:
ADMIN_PASSWORD_HASH=
# Or plain password for local dev only:
ADMIN_PASSWORD=

# --- Encrypted device credentials (LineMetrics clientSecret in DB) ---
# 32-byte key as 64 hex chars or base64; required in production when storing secrets.
CREDENTIALS_KEY=

# --- Scheduler (node-cron inside the Next.js process) ---
# Set to 1 to skip starting cron jobs (e.g. tests or minimal containers).
SCHEDULER_DISABLED=0
# If 1, /api/health expects the scheduler to be running (unless SCHEDULER_DISABLED=1).
SCHEDULER_ENABLED=0

# --- Output adapters ---
ADAPTER_TIMEOUT_MS=15000

# --- Legacy global LineMetrics env (optional; per-device config in DB is preferred) ---
LM_API_URL=https://restapi.linemetrics.com/v2
LM_CLIENT_ID=
LM_CLIENT_SECRET=
LM_USERNAME=
LM_PASSWORD=
LM_DEFAULT_CUSTOM_KEY=
LM_DEFAULT_ALIAS=

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=./logs/app.log
