# -----------------------------------------------------------------------------
# LM Webhook Next — environment configuration (copy to .env and adjust)
# -----------------------------------------------------------------------------

# HTTP port (Next.js / Docker)
PORT=3000

# Public URL of this app — required for server-side calls to /api/payload/decode
# On VPS behind HTTPS reverse proxy, set to https://your-domain
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Persistent data directory (devices.json, SQLite webhooks DB, decoders cache)
# Docker Compose mounts ./data to /app/data
DATA_DIR=./data

# Webhook source for GET /api/webhooks: local (SQLite) or webhooksite
WEBHOOK_SOURCE=local

# Optional: protect POST /api/webhooks/incoming
# Send header: Authorization: Bearer <WEBHOOK_SECRET> or X-Webhook-Secret: <WEBHOOK_SECRET>
# WEBHOOK_SECRET=

# webhook.site (only if WEBHOOK_SOURCE=webhooksite)
# WEBHOOK_SITE_TOKEN=
# WEBHOOK_SITE_API_KEY=

# LineMetrics (optional global defaults; per-device config can override in UI)
# LM_API_URL=https://rest-api.linemetrics.com
# LM_CLIENT_ID=
# LM_CLIENT_SECRET=
# LM_USERNAME=
# LM_PASSWORD=

# Logging
# LOG_LEVEL=info
# LOG_FILE=./logs/app.log
