          "code": "// TTN Codec: asset-tracker-2-codec\nfunction decodeUplink(input) {\n  // Auto-generated from TTN Device Repository\n  return {\n    data: {\n      raw: input.bytes,\n      fPort: input.fPort,\n      deviceModel: 'abeeway-compact-tracker',\n      manufacturer: 'abeeway'\n    },\n    warnings: [],\n    errors: []\n  };\n}",
