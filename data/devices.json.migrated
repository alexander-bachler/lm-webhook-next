          "code": "// TTN Codec: 3chbatteryvoltagesensor-codec\nfunction decodeUplink(input) {\n  // Auto-generated from TTN Device Repository\n  return {\n    data: {\n      raw: input.bytes,\n      fPort: input.fPort,\n      deviceModel: '3chbatteryvoltagesensor',\n      manufacturer: 'accuwatch'\n    },\n    warnings: [],\n    errors: []\n  };\n}",
